+        defaultKeyMaterial: KeyMaterial;
+    }): Promise<KeyMaterial | null> => {
+        if (!encryptedDataKey) {
+            return defaultKeyMaterial;
+        }
+
+        const decrypted = decryptSessionDataKey(encryptedDataKey, contentKeyPair.secretKey);
+        if (!decrypted) {
+            return null;
+        }
+
+        return {
+            key: decrypted,
+            variant: 'dataKey',
+        };
+    };
