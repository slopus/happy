+                body: JSON.stringify({ publicKey: '', challenge: '', signature: '' }),
+            });
+            if (response.status >= 400) {
+                return;
+            }
+        } catch {
+            // Server is not ready yet.
+        }
+        await new Promise((resolve) => setTimeout(resolve, 250));
+    }
+    throw new Error(`Timed out waiting for test server at ${url}`);
