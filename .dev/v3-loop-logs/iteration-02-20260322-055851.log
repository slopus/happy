+import { describe, expect, it } from 'vitest';
+import { convertV3ToAppMessages, isV3Envelope } from './v3Converter';
+
+const convert = (message: unknown) => convertV3ToAppMessages({
+    v: 3,
+    message: message as never,
+});
+
+const sessionId = 'ses_test';
+const userMessageId = 'msg_user';
+const assistantMessageId = 'msg_asst';
+
+const assistantInfo = (extra?: Record<string, unknown>) => ({
+    id: assistantMessageId,
+    sessionID: sessionId,
+    role: 'assistant' as const,
+    time: { created: 1000 },
+    parentID: userMessageId,
+    modelID: 'model-x',
+    providerID: 'provider-x',
+    agent: 'build',
+    path: { cwd: '/', root: '/' },
+    cost: 0,
+    tokens: { input: 0, output: 0, reasoning: 0, cache: { read: 0, write: 0 } },
+    ...extra,
+});
+
+describe('v3Converter', () => {
+    describe('isV3Envelope', () => {
+        it('detects a v3 envelope', () => {
+            expect(isV3Envelope({ v: 3, message: { info: {}, parts: [] } })).toBe(true);
+        });
+
+        it('rejects non-v3 payloads', () => {
+            expect(isV3Envelope({ role: 'user', content: { type: 'text' } })).toBe(false);
+            expect(isV3Envelope(null)).toBe(false);
+            expect(isV3Envelope({ v: 2 })).toBe(false);
+        });
+    });
+
+    it('converts a user message into a single user-text record', () => {
+        const messages = convert({
+            info: {
+                id: userMessageId,
+                sessionID: sessionId,
+                role: 'user',
+                time: { created: 1000 },
+                agent: 'build',
+                model: { providerID: 'anthropic', modelID: 'sonnet' },
+            },
+            parts: [{ id: 'p1', sessionID: sessionId, messageID: userMessageId, type: 'text', text: 'Hello' }],
+        });
+
+        expect(messages).toHaveLength(1);
+        expect(messages[0].kind).toBe('user-text');
+        if (messages[0].kind === 'user-text') {
+            expect(messages[0].text).toBe('Hello');
+        }
+    });
+
+    it('converts assistant text into an agent-text record', () => {
+        const messages = convert({
+            info: assistantInfo({ finish: 'stop' }),
+            parts: [
+                { id: 'ps', sessionID: sessionId, messageID: assistantMessageId, type: 'step-start' },
+                { id: 'p1', sessionID: sessionId, messageID: assistantMessageId, type: 'text', text: 'Answer.' },
+                {
+                    id: 'pf',
+                    sessionID: sessionId,
+                    messageID: assistantMessageId,
+                    type: 'step-finish',
+                    reason: 'stop',
+                    cost: 0,
+                    tokens: { input: 0, output: 0, reasoning: 0, cache: { read: 0, write: 0 } },
+                },
+            ],
+        });
+
+        expect(messages).toHaveLength(1);
+        expect(messages[0].kind).toBe('agent-text');
+        if (messages[0].kind === 'agent-text') {
+            expect(messages[0].isThinking).toBe(false);
+        }
+    });
+
+    it('converts reasoning parts into thinking agent-text records', () => {
+        const messages = convert({
+            info: assistantInfo(),
+            parts: [{ id: 'p1', sessionID: sessionId, messageID: assistantMessageId, type: 'reasoning', text: 'Thinking...', time: { start: 1000 } }],
+        });
+
+        expect(messages).toHaveLength(1);
+        if (messages[0].kind === 'agent-text') {
+            expect(messages[0].isThinking).toBe(true);
+        }
+    });
+
+    it('converts completed tool parts into tool-call records', () => {
+        const messages = convert({
+            info: assistantInfo({ finish: 'tool-calls' }),
+            parts: [{
+                id: 'p1',
+                sessionID: sessionId,
+                messageID: assistantMessageId,
+                type: 'tool',
+                callID: 'c1',
+                tool: 'writeFile',
+                state: {
+                    status: 'completed',
+                    input: { path: 'x' },
+                    output: 'Done',
+                    title: 'writeFile',
+                    metadata: {},
+                    time: { start: 1000, end: 1500 },
+                },
+            }],
+        });
+
+        expect(messages).toHaveLength(1);
+        expect(messages[0].kind).toBe('tool-call');
+        if (messages[0].kind === 'tool-call') {
+            expect(messages[0].tool.state).toBe('completed');
+            expect(messages[0].tool.result).toBe('Done');
+        }
+    });
+
+    it('maps blocked permission tools to pending permission state', () => {
+        const messages = convert({
+            info: assistantInfo(),
+            parts: [{
+                id: 'p1',
+                sessionID: sessionId,
+                messageID: assistantMessageId,
+                type: 'tool',
+                callID: 'c1',
+                tool: 'writeFile',
+                state: {
+                    status: 'blocked',
+                    input: { path: 'x' },
+                    time: { start: 1000 },
+                    block: {
+                        type: 'permission',
+                        id: 'perm1',
+                        permission: 'edit',
+                        patterns: ['x'],
+                        always: ['*'],
+                        metadata: {},
+                    },
+                },
+            }],
+        });
+
+        expect(messages).toHaveLength(1);
+        if (messages[0].kind === 'tool-call') {
+            expect(messages[0].tool.state).toBe('running');
+            expect(messages[0].tool.permission?.status).toBe('pending');
+        }
+    });
+
+    it('preserves resolved permission decisions on completed tools', () => {
+        const messages = convert({
+            info: assistantInfo(),
+            parts: [{
+                id: 'p1',
+                sessionID: sessionId,
+                messageID: assistantMessageId,
+                type: 'tool',
+                callID: 'c1',
+                tool: 'writeFile',
+                state: {
+                    status: 'completed',
+                    input: {},
+                    output: 'Done',
+                    title: 'writeFile',
+                    metadata: {},
+                    time: { start: 1000, end: 2000 },
+                    block: {
+                        type: 'permission',
+                        id: 'perm1',
+                        permission: 'edit',
+                        patterns: ['x'],
+                        always: ['*'],
+                        metadata: {},
+                        decision: 'once',
+                        decidedAt: 1500,
+                    },
+                },
+            }],
+        });
+
+        expect(messages).toHaveLength(1);
+        if (messages[0].kind === 'tool-call') {
+            expect(messages[0].tool.permission?.status).toBe('approved');
+            expect(messages[0].tool.permission?.decision).toBe('approved');
+            expect(messages[0].tool.permission?.date).toBe(1500);
+        }
+    });
+
+    it('preserves rejected permission decisions on errored tools', () => {
+        const messages = convert({
+            info: assistantInfo(),
+            parts: [{
+                id: 'p1',
+                sessionID: sessionId,
+                messageID: assistantMessageId,
+                type: 'tool',
+                callID: 'c1',
+                tool: 'writeFile',
+                state: {
+                    status: 'error',
+                    input: {},
+                    error: 'Rejected',
+                    time: { start: 1000, end: 1500 },
+                    block: {
+                        type: 'permission',
+                        id: 'perm1',
+                        permission: 'edit',
+                        patterns: ['x'],
+                        always: ['*'],
+                        metadata: {},
+                        decision: 'reject',
+                        decidedAt: 1400,
+                    },
+                },
+            }],
+        });
+
+        expect(messages).toHaveLength(1);
+        if (messages[0].kind === 'tool-call') {
+            expect(messages[0].tool.state).toBe('error');
+            expect(messages[0].tool.permission?.status).toBe('denied');
+        }
+    });
+
+    it('skips structural-only messages', () => {
+        const messages = convert({
+            info: assistantInfo(),
+            parts: [
+                { id: 'p1', sessionID: sessionId, messageID: assistantMessageId, type: 'step-start' },
+                { id: 'p2', sessionID: sessionId, messageID: assistantMessageId, type: 'snapshot', snapshot: 'abc' },
+                { id: 'p3', sessionID: sessionId, messageID: assistantMessageId, type: 'patch', hash: 'def', files: ['a.ts'] },
+                {
+                    id: 'p4',
+                    sessionID: sessionId,
+                    messageID: assistantMessageId,
+                    type: 'step-finish',
+                    reason: 'stop',
+                    cost: 0,
+                    tokens: { input: 0, output: 0, reasoning: 0, cache: { read: 0, write: 0 } },
+                },
+            ],
+        });
+
+        expect(messages).toHaveLength(0);
+    });
+});
diff --git a/packages/happy-app/sources/sync/v3Converter.ts b/packages/happy-app/sources/sync/v3Converter.ts
new file mode 100644
index 0000000000000000000000000000000000000000..caf361ac76b15f3bde40ad316958484de17e3e9b
--- /dev/null
+++ b/packages/happy-app/sources/sync/v3Converter.ts
@@ -0,0 +1,277 @@
+/**
+ * Temporary v3 compatibility shim for the legacy app store.
+ *
+ * The refactor plan moves the app to direct `MessageWithParts` rendering, but
+ * the current app still ingests flat `Message[]` records through `sync.ts`.
+ * Until the store/UI migration lands, keep the v3-to-flat conversion isolated
+ * here so the branch remains buildable.
+ */
+
+import type { v3 } from '@slopus/happy-sync';
+import type {
+    AgentTextMessage,
+    Message,
+    ToolCall,
+    ToolCallMessage,
+    UserTextMessage,
+} from './typesMessage';
+
+type MessageWithParts = v3.MessageWithParts;
+type Part = v3.Part;
+
+export function isV3Envelope(payload: unknown): payload is { v: 3; message: MessageWithParts } {
+    if (!payload || typeof payload !== 'object') {
+        return false;
+    }
+
+    const value = payload as Record<string, unknown>;
+    return value.v === 3 && value.message !== null && typeof value.message === 'object';
+}
+
+export function convertV3ToAppMessages(envelope: { v: 3; message: MessageWithParts }): Message[] {
+    const { info, parts } = envelope.message;
+
+    if (info.role === 'user') {
+        return convertUserMessage(info, parts);
+    }
+
+    if (info.role === 'assistant') {
+        return convertAssistantMessage(info, parts);
+    }
+
+    return [];
+}
+
+function convertUserMessage(info: v3.UserMessage, parts: Part[]): Message[] {
+    const textParts = parts.filter((part): part is v3.TextPart => part.type === 'text' && !part.synthetic);
+    const text = textParts.map((part) => part.text).join('\n');
+
+    if (text.trim().length === 0) {
+        return [];
+    }
+
+    const message: UserTextMessage = {
+        kind: 'user-text',
+        id: info.id,
+        localId: null,
+        createdAt: info.time.created,
+        text,
+    };
+    return [message];
+}
+
+function convertAssistantMessage(info: v3.AssistantMessage, parts: Part[]): Message[] {
+    const messages: Message[] = [];
+    let partOffset = 0;
+
+    for (const part of parts) {
+        if (isStructuralPart(part)) {
+            continue;
+        }
+
+        if (part.type === 'text') {
+            const message: AgentTextMessage = {
+                kind: 'agent-text',
+                id: part.id,
+                localId: null,
+                createdAt: info.time.created + partOffset++,
+                text: part.text,
+                isThinking: false,
+            };
+            messages.push(message);
+            continue;
+        }
+
+        if (part.type === 'reasoning') {
+            const message: AgentTextMessage = {
+                kind: 'agent-text',
+                id: part.id,
+                localId: null,
+                createdAt: info.time.created + partOffset++,
+                text: part.text,
+                isThinking: true,
+            };
+            messages.push(message);
+            continue;
+        }
+
+        if (part.type === 'tool') {
+            const toolCall = convertToolPart(part);
+            const message: ToolCallMessage = {
+                kind: 'tool-call',
+                id: part.id,
+                localId: null,
+                createdAt: info.time.created + partOffset++,
+                tool: toolCall,
+                children: [],
+            };
+            messages.push(message);
+            continue;
+        }
+
+        if (part.type === 'file') {
+            const message: AgentTextMessage = {
+                kind: 'agent-text',
+                id: part.id,
+                localId: null,
+                createdAt: info.time.created + partOffset++,
+                text: `[Attached ${part.mime}: ${part.filename ?? 'file'}]`,
+            };
+            messages.push(message);
+        }
+    }
+
+    return messages;
+}
+
+function isStructuralPart(part: Part): boolean {
+    switch (part.type) {
+        case 'step-start':
+        case 'step-finish':
+        case 'snapshot':
+        case 'patch':
+        case 'compaction':
+        case 'retry':
+        case 'agent':
+        case 'subtask':
+        case 'decision':
+        case 'answer':
+            return true;
+        default:
+            return false;
+    }
+}
+
+function convertToolPart(part: v3.ToolPart): ToolCall {
+    const state = part.state;
+    const input = normalizeBashInput(part.tool, state.input);
+    const base: Omit<ToolCall, 'state'> = {
+        name: part.tool,
+        input,
+        createdAt: Date.now(),
+        startedAt: 'time' in state && state.time ? state.time.start : null,
+        completedAt: null,
+        description: null,
+        result: undefined,
+        permission: undefined,
+    };
+
+    switch (state.status) {
+        case 'pending':
+            return { ...base, state: 'running' };
+
+        case 'running':
+            return {
+                ...base,
+                state: 'running',
+                description: state.title ?? null,
+            };
+
+        case 'blocked': {
+            const permission = convertPendingBlock(state.block);
+            return {
+                ...base,
+                state: 'running',
+                description: state.title ?? null,
+                permission,
+            };
+        }
+
+        case 'completed':
+            return {
+                ...base,
+                state: 'completed',
+                description: state.title,
+                result: state.output,
+                completedAt: state.time.end,
+                permission: convertResolvedBlock(state.block),
+            };
+
+        case 'error':
+            return {
+                ...base,
+                state: 'error',
+                result: state.error,
+                completedAt: state.time.end,
+                permission: convertResolvedBlock(state.block),
+            };
+    }
+}
+
+function convertPendingBlock(block: v3.Block): ToolCall['permission'] {
+    if (block.type === 'permission') {
+        const reason = getPermissionReason(block.metadata);
+        return {
+            id: block.id,
+            status: 'pending',
+            reason,
+        };
+    }
+
+    return {
+        id: block.id,
+        status: 'pending',
+    };
+}
+
+function getPermissionReason(metadata: Record<string, unknown>): string | undefined {
+    const reason = metadata.reason;
+    return typeof reason === 'string' ? reason : undefined;
+}
+
+function normalizeBashInput(tool: string, input: unknown): unknown {
+    if (!isTerminalLikeTool(tool) || !input || typeof input !== 'object') {
+        return input;
+    }
+
+    const value = input as Record<string, unknown>;
+    if (typeof value.command !== 'string') {
+        return input;
+    }
+
+    let command = value.command;
+    const shellMatch = command.match(/^\/bin\/(?:ba)?sh\s+-lc\s+'(.+)'$/s)
+        ?? command.match(/^\/bin\/(?:ba)?sh\s+-lc\s+"(.+)"$/s)
+        ?? command.match(/^\/bin\/zsh\s+-lc\s+'(.+)'$/s)
+        ?? command.match(/^\/bin\/zsh\s+-lc\s+"(.+)"$/s);
+    if (shellMatch) {
+        command = shellMatch[1];
+    }
+
+    return {
+        command,
+        description: typeof value.description === 'string' ? value.description : undefined,
+    };
+}
+
+function isTerminalLikeTool(tool: string): boolean {
+    return tool === 'bash'
+        || tool === 'Bash'
+        || tool === 'terminal'
+        || tool === 'Terminal';
+}
+
+function convertResolvedBlock(block: v3.ResolvedBlock | undefined): ToolCall['permission'] {
+    if (!block) {
+        return undefined;
+    }
+
+    if (block.type === 'permission') {
+        return {
+            id: block.id,
+            status: block.decision === 'reject' ? 'denied' : 'approved',
+            decision: block.decision === 'once'
+                ? 'approved'
+                : block.decision === 'always'
+                    ? 'approved_for_session'
+                    : 'denied',
+            date: block.decidedAt,
+        };
+    }
+
+    return {
+        id: block.id,
+        status: 'approved',
+        date: block.decidedAt,
+    };
+}
