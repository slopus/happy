+});
+
+export const sessionEventSchema = z.discriminatedUnion('t', [
+  sessionTextEventSchema,
+  sessionServiceMessageEventSchema,
+  sessionToolCallStartEventSchema,
+  sessionToolCallEndEventSchema,
