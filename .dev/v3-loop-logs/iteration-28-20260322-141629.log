+  id?: string;
+  time?: number;
+  turn?: string;
+  subagent?: string;
+};
+
+export function createEnvelope(role: SessionRole, ev: SessionEvent, opts: CreateEnvelopeOptions = {}): SessionEnvelope {
+  return sessionEnvelopeSchema.parse({
+    id: opts.id ?? createId(),
+    time: opts.time ?? Date.now(),
