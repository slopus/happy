+            decision: 'always',
+            allowTools: ['Write'],
+        });
+        expect(sessionRPC).not.toHaveBeenCalled();
+    });
+
+    it('falls back to legacy RPC approval when no v3 permission request exists', async () => {
+        await sessionAllow('ses_1', 'perm_1');
+
+        expect(sessionRPC).toHaveBeenCalledWith('ses_1', 'permission', {
