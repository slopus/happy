+            : null;
 
-    if (normalizedName === 'build, build') {
-        return { ...mode, name: 'build' };
+    if (!canonicalName) {
+        return mode;
     }
-    if (normalizedName === 'plan/plan') {
-        return { ...mode, name: 'plan' };
+
+    if (
+        normalizedName === normalizedKey
+        || normalizedName === `${normalizedKey}, ${normalizedKey}`
+        || normalizedName === `${normalizedKey}/${normalizedKey}`
+    ) {
+        return { ...mode, name: canonicalName };
     }
+
     return mode;
 }
 
