+                status: 'blocked',
+                input: {
+                    questions: [{
+                        header: 'Framework',
+                        question: 'Which test framework should I use?',
+                        options: [
+                            { label: 'Vitest', description: 'Fast Vite-native testing' },
+                        ],
+                    }],
+                },
+                title: 'Ask a question',
+                time: { start: 123 },
+                block: {
+                    type: 'question',
+                    id: 'question_1',
+                    questions: [{
+                        header: 'Framework',
+                        question: 'Which test framework should I use?',
+                        options: [
+                            { label: 'Vitest', description: 'Fast Vite-native testing' },
+                        ],
+                    }],
+                },
+            },
+        };
+
+        expect(toolPartToToolCall(part)).toMatchObject({
+            name: 'AskUserQuestion',
+            state: 'running',
+            permission: {
+                id: 'question_1',
+                status: 'pending',
+            },
+        });
+    });
+});
