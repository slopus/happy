+import { describe, expect, it } from 'vitest';
+import { type v3 } from '@slopus/happy-sync';
+import { toolPartToToolCall } from './toolPartToToolCall';
+
+describe('toolPartToToolCall', () => {
+    it('maps blocked question tools into a pending interaction', () => {
+        const part: v3.ToolPart = {
+            id: 'prt_question' as v3.PartID,
+            sessionID: 'ses_1' as v3.SessionID,
+            messageID: 'msg_1' as v3.MessageID,
+            type: 'tool',
+            callID: 'call_question',
+            tool: 'AskUserQuestion',
+            state: {
+                status: 'blocked',
+                input: {
+                    questions: [{
+                        header: 'Framework',
+                        question: 'Which test framework should I use?',
+                        options: [
+                            { label: 'Vitest', description: 'Fast Vite-native testing' },
+                        ],
+                    }],
+                },
+                title: 'Ask a question',
+                time: { start: 123 },
+                block: {
+                    type: 'question',
+                    id: 'question_1',
+                    questions: [{
+                        header: 'Framework',
+                        question: 'Which test framework should I use?',
+                        options: [
+                            { label: 'Vitest', description: 'Fast Vite-native testing' },
+                        ],
+                    }],
+                },
+            },
+        };
+
+        expect(toolPartToToolCall(part)).toMatchObject({
+            name: 'AskUserQuestion',
+            state: 'running',
+            permission: {
+                id: 'question_1',
+                status: 'pending',
+            },
+        });
+    });
+});
