diff --git a/packages/happy-app/sources/components/parts/toolPartToToolCall.ts b/packages/happy-app/sources/components/parts/toolPartToToolCall.ts
new file mode 100644
index 0000000000000000000000000000000000000000..d1a5cb55f6dfd07bb178c80c7e1455a7b17cbc97
--- /dev/null
+++ b/packages/happy-app/sources/components/parts/toolPartToToolCall.ts
@@ -0,0 +1,110 @@
+import { type v3 } from '@slopus/happy-sync';
+import type { ToolCall } from '@/sync/typesMessage';
+
+/**
+ * Extract the fields ToolView needs from a v3 ToolPart.
+ * The ToolPart remains the source of truth; this only reshapes it for rendering.
+ */
+export function toolPartToToolCall(part: v3.ToolPart): ToolCall {
+    const s = part.state;
+    const base = {
+        name: part.tool,
+        input: s.input,
+        description: ('title' in s && s.title) ? s.title : null,
+    };
+
+    switch (s.status) {
+        case 'pending':
+            return {
+                ...base,
+                state: 'running',
+                createdAt: Date.now(),
+                startedAt: null,
+                completedAt: null,
+            };
+
+        case 'running':
+            return {
+                ...base,
+                state: 'running',
+                createdAt: s.time.start,
+                startedAt: s.time.start,
+                completedAt: null,
+            };
+
+        case 'blocked': {
+            const block = s.block;
+            const permission = {
+                id: block.id,
+                status: 'pending' as const,
+                reason: undefined,
+                mode: undefined,
+                allowedTools: block.type === 'permission' ? block.always : undefined,
+                decision: undefined,
+                date: undefined,
+            };
+            return {
+                ...base,
+                state: 'running',
+                createdAt: s.time.start,
+                startedAt: s.time.start,
+                completedAt: null,
+                permission,
+            };
+        }
+
+        case 'completed': {
+            const permission = s.block
+                ? s.block.type === 'permission'
+                    ? {
+                        id: s.block.id,
+                        status: (s.block.decision === 'reject' ? 'denied' : 'approved') as 'approved' | 'denied',
+                        decision: (s.block.decision === 'once' ? 'approved' : s.block.decision === 'always' ? 'approved_for_session' : 'denied') as 'approved' | 'approved_for_session' | 'denied',
+                        date: s.block.decidedAt,
+                    }
+                    : {
+                        id: s.block.id,
+                        status: 'approved' as const,
+                        decision: 'approved' as const,
+                        date: s.block.decidedAt,
+                    }
+                : undefined;
+            return {
+                ...base,
+                state: 'completed',
+                createdAt: s.time.start,
+                startedAt: s.time.start,
+                completedAt: s.time.end,
+                result: s.output,
+                permission,
+            };
+        }
+
+        case 'error': {
+            const permission = s.block
+                ? s.block.type === 'permission'
+                    ? {
+                        id: s.block.id,
+                        status: (s.block.decision === 'reject' ? 'denied' : 'approved') as 'approved' | 'denied',
+                        decision: (s.block.decision === 'reject' ? 'denied' : 'approved') as 'approved' | 'denied',
+                        date: s.block.decidedAt,
+                    }
+                    : {
+                        id: s.block.id,
+                        status: 'approved' as const,
+                        decision: 'approved' as const,
+                        date: s.block.decidedAt,
+                    }
+                : undefined;
+            return {
+                ...base,
+                state: 'error',
+                createdAt: s.time.start,
+                startedAt: s.time.start,
+                completedAt: s.time.end,
+                result: s.error,
+                permission,
+            };
+        }
+    }
+}
