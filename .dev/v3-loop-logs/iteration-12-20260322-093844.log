+import { z } from 'zod';
+
+export const SyncNodeTokenClaimsSchema = z.object({
+    scope: z.discriminatedUnion('type', [
+        z.object({
+            type: z.literal('account'),
+            userId: z.string(),
+        }),
+        z.object({
+            type: z.literal('session'),
+            userId: z.string(),
+            sessionId: z.string(),
+        }),
+    ]),
+    permissions: z.array(z.enum(['read', 'write', 'admin'])),
+});
+export type SyncNodeTokenClaims = z.infer<typeof SyncNodeTokenClaimsSchema>;
+
+export interface SyncNodeToken {
+    raw: string;
+    claims: SyncNodeTokenClaims;
+}

tokens used
299,814
Implemented a focused spec-alignment pass around the new sync path.

- Session processes now attach `SyncNode` with a real session-scoped token instead of reusing the account token. `ApiSessionClient.attachSyncBridge()` mints `/v1/sessions/:id/token` when needed in [apiSession.ts](/Users/kirilldubovitskiy/projects/happy/.dev/worktree/happy-sync-refactor/packages/happy-cli/src/api/apiSession.ts), and [syncBridge.ts](/Users/kirilldubovitskiy/projects/happy/.dev/worktree/happy-sync-refactor/packages/happy-cli/src/api/syncBridge.ts) now rejects non-session tokens.
- The shared token-claims schema was extracted to [token.ts](/Users/kirilldubovitskiy/projects/happy/.dev/worktree/happy-sync-refactor/packages/happy-sync/src/token.ts) and re-exported from [sync-node.ts](/Users/kirilldubovitskiy/projects/happy/.dev/worktree/happy-sync-refactor/packages/happy-sync/src/sync-node.ts). That lets the server validate the same schema in source mode from [syncNodeToken.ts](/Users/kirilldubovitskiy/projects/happy/.dev/worktree/happy-sync-refactor/packages/happy-server/sources/app/auth/syncNodeToken.ts) without depending on a built `dist` import. I also switched the daemon mint-response parsing to the shared schema in [daemon/syncNode.ts](/Users/kirilldubovitskiy/projects/happy/.dev/worktree/happy-sync-refactor/packages/happy-cli/src/daemon/syncNode.ts).
- Codex reasoning/diff side channels no longer dual-write legacy `session` envelopes in the main runtime path. [runCodex.ts](/Users/kirilldubovitskiy/projects/happy/.dev/worktree/happy-sync-refactor/packages/happy-cli/src/codex/runCodex.ts) now routes those synthetic updates back through the v3 mapper, and [v3Mapper.ts](/Users/kirilldubovitskiy/projects/happy/.dev/worktree/happy-sync-refactor/packages/happy-cli/src/codex/utils/v3Mapper.ts) now understands synthetic `reasoning`, `tool-call`, and `tool-call-result` events. Coverage was added in [v3Mapper.test.ts](/Users/kirilldubovitskiy/projects/happy/.dev/worktree/happy-sync-refactor/packages/happy-cli/src/codex/utils/v3Mapper.test.ts) and [apiSession.test.ts](/Users/kirilldubovitskiy/projects/happy/.dev/worktree/happy-sync-refactor/packages/happy-cli/src/api/apiSession.test.ts).

Verified:
- `yarn workspace happy-coder typecheck`
- `npx vitest run --project unit src/api/apiSession.test.ts src/codex/utils/v3Mapper.test.ts`
- `yarn workspace happy-server build`
- `yarn workspace happy-server test sources/app/api/routes/v3SessionRoutes.test.ts`
- `yarn workspace @slopus/happy-sync test:unit`
- `yarn workspace @slopus/happy-sync test:integration`

This does not finish the entire refactor spec yet. The largest remaining gaps are the other legacy runtime paths outside Codex, the app-side legacy sync/rendering pipeline, and the Level 2/3 end-to-end/browser coverage.
