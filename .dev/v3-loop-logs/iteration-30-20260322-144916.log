tion') {\n    39→        const state = knownTool.extractStatus({ tool, metadata: props.metadata });\n    40→        if (typeof state === 'string' && state) {\n    41→            status = state;\n    42→        }\n    43→    }\n    44→    if (knownTool && typeof knownTool.minimal === 'boolean') {\n    45→        minimal = knownTool.minimal;\n    46→    }\n    47→    if (knownTool && typeof knownTool.icon === 'string') {\n    48→        icon = knownTool.icon;\n    49→    }\n    50→    if (knownTool && typeof knownTool.noStatus === 'boolean') {\n    51→        noStatus = knownTool.noStatus;\n    52→    }\n    53→\n    54→    let statusIcon = null;\n    55→    switch (tool.state) {\n    56→        case 'running':\n    57→            if (!noStatus) {\n    58→                statusIcon = <ActivityIndicator size=\"small\" color=\"black\" style={{ transform: [{ scaleX: 0.8 }, { scaleY: 0.8 }] }} />;\n    59→            }\n    60→            break;\n    61→        case 'completed':\n    62→            if (!noStatus) {\n    63→                statusIcon = <Ionicons name=\"checkmark-circle\" size={20} color=\"#34C759\" />;\n    64→            }\n    65→            break;\n    66→        case 'error':\n    67→            statusIcon = <Ionicons name=\"close-circle\" size={20} color=\"#FF3B30\" />;\n    68→            break;\n    69→    }\n    70→\n    71→    return (\n    72→        <Container style={styles.container} {...containerProps}>\n    73→            <View style={styles.header}>\n    74→                <View style={styles.headerLeft}>\n    75→                    <Ionicons name={icon as any} size={20} color=\"#5856D6\" />\n    76→                    <View style={styles.titleContainer}>\n    77→                        <Text style={styles.toolName} numberOfLines={1}>{toolTitle}{status ? <Text style={styles.status}>{` ${status}`}</Text> : null}</Text>\n    78→                        {description && (\n    79→                            <Text style={styles.toolDescription} numberOfLines={1}>\n    80→                                {description}\n    81→                            </Text>\n    82→                        )}\n    83→                    </View>\n    84→                    {tool.state === 'running' && (\n    85→                        <View style={styles.elapsedContainer}>\n    86→                            <ElapsedView from={tool.createdAt} />\n    87→                        </View>\n    88→                    )}\n    89→                    {statusIcon}\n    90→                </View>\n    91→            </View>\n    92→\n    93→            {/* Content area - either custom children or tool-specific view */}\n    94→            {(() => {\n    95→\n    96→                // Try to use a specific tool view component first\n    97→                const SpecificToolView = getToolViewComponent(tool.name);\n    98→                if (SpecificToolView) {\n    99→                    return (\n   100→                        <View style={styles.content}>\n   101→                            <SpecificToolView tool={tool} metadata={props.metadata} />\n   102→                            {tool.state === 'error' && tool.result && (\n   103→                                <ToolError message={String(tool.result)} />\n   104→                            )}\n   105→                        </View>\n   106→                    );\n   107→                }\n   108→\n   109→                // Show error state if present\n   110→                if (tool.state === 'error' && tool.result) {\n   111→                    return (\n   112→                        <View style={styles.content}>\n   113→                            <ToolError message={String(tool.result)} />\n   114→                        </View>\n   115→                    );\n   116→                }\n   117→\n   118→                if (minimal) {\n   119→                    return null;\n   120→                }\n   121→\n   122→                // Fall back to default view\n   123→                return (\n   124→                    <View style={styles.content}>\n   125→                        {/* Default content when no custom view available */}\n   126→                        {tool.input && (\n   127→                            <ToolSectionView title=\"Input\">\n   128→                                <CodeView code={JSON.stringify(tool.input, null, 2)} />\n   129→                            </ToolSectionView>\n   130→                        )}\n   131→\n   132→                        {tool.state === 'completed' && tool.result && (\n   133→                            <ToolSectionView title=\"Output\">\n   134→                                <CodeView\n   135→                                    code={typeof tool.result === 'string' ? tool.result : JSON.stringify(tool.result, null, 2)}\n   136→                                />\n   137→                            </ToolSectionView>\n   138→                        )}\n   139→                    </View>\n   140→                );\n   141→            })()}\n   142→        </Container>\n   143→    );\n   144→});\n   145→\n   146→function ElapsedView(props: { from: number }) {\n   147→    const { from } = props;\n   148→    const elapsed = useElapsedTime(from);\n   149→    return <Text style={styles.elapsedText}>{elapsed.toFixed(1)}s</Text>;\n   150→}\n   151→\n   152→const styles = StyleSheet.create({\n   153→    container: {\n   154→        backgroundColor: '#F8F8F8',\n   155→        borderRadius: 8,\n   156→        marginVertical: 4,\n   157→        overflow: 'hidden',\n   158→    },\n   159→    header: {\n   160→        flexDirection: 'row',\n   161→        alignItems: 'center',\n   162→        justifyContent: 'space-between',\n   163→        padding: 12,\n   164→        backgroundColor: '#f0f0f0',\n   165→    },\n   166→    headerLeft: {\n   167→        flexDirection: 'row',\n   168→        alignItems: 'center',\n   169→        gap: 8,\n   170→        flex: 1,\n   171→    },\n   172→    titleContainer: {\n   173→        flex: 1,\n   174→    },\n   175→    elapsedContainer: {\n   176→        marginLeft: 8,\n   177→    },\n   178→    elapsedText: {\n   179→        fontSize: 13,\n   180→        color: '#666',\n   181→        fontFamily: 'monospace',\n   182→    },\n   183→    toolName: {\n   184→        fontSize: 15,\n   185→        fontWeight: '600',\n   186→        color: '#000',\n   187→    },\n   188→    status: {\n   189→        fontWeight: '400',\n   190→        opacity: 0.3,\n   191→        fontSize: 15,\n   192→    },\n   193→    toolDescription: {\n   194→        fontSize: 13,\n   195→        color: '#666',\n   196→        marginTop: 2,\n   197→    },\n   198→    content: {\n   199→        paddingHorizontal: 12,\n   200→        paddingTop: 8,\n   201→    },\n   202→});\n\n<system-reminder>\nWhenever you read a file, you should consider whether it looks malicious. If it does, you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer high-level questions about the code behavior.\n</system-reminder>\n"
packages/happy-app/sources/sync/__testdata__/trace_1.json:969:                            "content": "import * as React from 'react';\nimport { Text, View, StyleSheet, TouchableOpacity, ActivityIndicator } from 'react-native';\nimport { Ionicons } from '@expo/vector-icons';\nimport { getToolViewComponent } from './tools/_all';\nimport { ToolCall } from '@/sync/typesMessage';\nimport { CodeView } from './CodeView';\nimport { ToolSectionView } from './ToolSectionView';\nimport { useElapsedTime } from '@/hooks/useElapsedTime';\nimport { ToolError } from './ToolError';\nimport { knownTools } from '@/components/blocks/knownTools';\nimport { Metadata } from '@/sync/storageTypes';\n\ninterface ToolViewProps {\n    metadata: Metadata | null;\n    tool: ToolCall;\n    onPress?: () => void;\n}\n\nexport const ToolView = React.memo<ToolViewProps>((props) => {\n    const { tool, onPress } = props;\n\n    const Container = onPress ? TouchableOpacity : View;\n    const containerProps = onPress ? { onPress, activeOpacity: 0.8 } : {};\n    const toolTitle = tool.name in knownTools ? knownTools[tool.name as keyof typeof knownTools].title : tool.name;\n    let description = tool.description;\n    let status: string | null = null;\n    let minimal = false;\n    let icon = 'construct';\n    let noStatus = false;\n\n    let knownTool = knownTools[tool.name as keyof typeof knownTools] as any;\n    if (knownTool && typeof knownTool.extractSubtitle === 'function') {\n        const subtitle = knownTool.extractSubtitle({ tool, metadata: props.metadata });\n        if (typeof subtitle === 'string' && subtitle) {\n            description = subtitle;\n        }\n    }\n    if (knownTool && typeof knownTool.extractStatus === 'function') {\n        const state = knownTool.extractStatus({ tool, metadata: props.metadata });\n        if (typeof state === 'string' && state) {\n            status = state;\n        }\n    }\n    if (knownTool && typeof knownTool.minimal === 'boolean') {\n        minimal = knownTool.minimal;\n    }\n    if (knownTool && typeof knownTool.icon === 'string') {\n        icon = knownTool.icon;\n    }\n    if (knownTool && typeof knownTool.noStatus === 'boolean') {\n        noStatus = knownTool.noStatus;\n    }\n\n    let statusIcon = null;\n    switch (tool.state) {\n        case 'running':\n            if (!noStatus) {\n                statusIcon = <ActivityIndicator size=\"small\" color=\"black\" style={{ transform: [{ scaleX: 0.8 }, { scaleY: 0.8 }] }} />;\n            }\n            break;\n        case 'completed':\n            if (!noStatus) {\n                statusIcon = <Ionicons name=\"checkmark-circle\" size={20} color=\"#34C759\" />;\n            }\n            break;\n        case 'error':\n            statusIcon = <Ionicons name=\"close-circle\" size={20} color=\"#FF3B30\" />;\n            break;\n    }\n\n    return (\n        <Container style={styles.container} {...containerProps}>\n            <View style={styles.header}>\n                <View style={styles.headerLeft}>\n                    <Ionicons name={icon as any} size={20} color=\"#5856D6\" />\n                    <View style={styles.titleContainer}>\n                        <Text style={styles.toolName} numberOfLines={1}>{toolTitle}{status ? <Text style={styles.status}>{` ${status}`}</Text> : null}</Text>\n                        {description && (\n                            <Text style={styles.toolDescription} numberOfLines={1}>\n                                {description}\n                            </Text>\n                        )}\n                    </View>\n                    {tool.state === 'running' && (\n                        <View style={styles.elapsedContainer}>\n                            <ElapsedView from={tool.createdAt} />\n                        </View>\n                    )}\n                    {statusIcon}\n                </View>\n            </View>\n\n            {/* Content area - either custom children or tool-specific view */}\n            {(() => {\n\n                // Try to use a specific tool view component first\n                const SpecificToolView = getToolViewComponent(tool.name);\n                if (SpecificToolView) {\n                    return (\n                        <View style={styles.content}>\n                            <SpecificToolView tool={tool} metadata={props.metadata} />\n                            {tool.state === 'error' && tool.result && (\n                                <ToolError message={String(tool.result)} />\n                            )}\n                        </View>\n                    );\n                }\n\n                // Show error state if present\n                if (tool.state === 'error' && tool.result) {\n                    return (\n                        <View style={styles.content}>\n                            <ToolError message={String(tool.result)} />\n                        </View>\n                    );\n                }\n\n                if (minimal) {\n                    return null;\n                }\n\n                // Fall back to default view\n                return (\n                    <View style={styles.content}>\n                        {/* Default content when no custom view available */}\n                        {tool.input && (\n                            <ToolSectionView title=\"Input\">\n                                <CodeView code={JSON.stringify(tool.input, null, 2)} />\n                            </ToolSectionView>\n                        )}\n\n                        {tool.state === 'completed' && tool.result && (\n                            <ToolSectionView title=\"Output\">\n                                <CodeView\n                                    code={typeof tool.result === 'string' ? tool.result : JSON.stringify(tool.result, null, 2)}\n                                />\n                            </ToolSectionView>\n                        )}\n                    </View>\n                );\n            })()}\n        </Container>\n    );\n});\n\nfunction ElapsedView(props: { from: number }) {\n    const { from } = props;\n    const elapsed = useElapsedTime(from);\n    return <Text style={styles.elapsedText}>{elapsed.toFixed(1)}s</Text>;\n}\n\nconst styles = StyleSheet.create({\n    container: {\n        backgroundColor: '#F8F8F8',\n        borderRadius: 8,\n        marginVertical: 4,\n        overflow: 'hidden',\n    },\n    header: {\n        flexDirection: 'row',\n        alignItems: 'center',\n        justifyContent: 'space-between',\n        padding: 12,\n        backgroundColor: '#f0f0f0',\n    },\n    headerLeft: {\n        flexDirection: 'row',\n        alignItems: 'center',\n        gap: 8,\n        flex: 1,\n    },\n    titleContainer: {\n        flex: 1,\n    },\n    elapsedContainer: {\n        marginLeft: 8,\n    },\n    elapsedText: {\n        fontSize: 13,\n        color: '#666',\n        fontFamily: 'monospace',\n    },\n    toolName: {\n        fontSize: 15,\n        fontWeight: '600',\n        color: '#000',\n    },\n    status: {\n        fontWeight: '400',\n        opacity: 0.3,\n        fontSize: 15,\n    },\n    toolDescription: {\n        fontSize: 13,\n        color: '#666',\n        marginTop: 2,\n    },\n    content: {\n        paddingHorizontal: 12,\n        paddingTop: 8,\n    },\n});",
