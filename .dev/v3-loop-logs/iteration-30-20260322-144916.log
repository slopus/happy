+
+            if (multiple) {
+                const updated = new Set(existing);
+                if (updated.has(optionIndex)) {
+                    updated.delete(optionIndex);
+                } else {
+                    updated.add(optionIndex);
+                }
+                next.set(questionIndex, updated);
+                return next;
+            }
+
+            next.set(questionIndex, new Set([optionIndex]));
+            return next;
+        });
