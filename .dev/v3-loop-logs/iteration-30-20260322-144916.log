ownTool.extractStatus === 'function') {\n    40→        const state = knownTool.extractStatus({ tool, metadata: props.metadata });\n    41→        if (typeof state === 'string' && state) {\n    42→            status = state;\n    43→        }\n    44→    }\n    45→    if (knownTool && typeof knownTool.minimal === 'boolean') {\n    46→        minimal = knownTool.minimal;\n    47→    }\n    48→    if (knownTool && typeof knownTool.icon === 'string') {\n    49→        icon = knownTool.icon;\n    50→    }\n    51→    if (knownTool && typeof knownTool.noStatus === 'boolean') {\n    52→        noStatus = knownTool.noStatus;\n    53→    }\n    54→\n    55→    let statusIcon = null;\n    56→    switch (tool.state) {\n    57→        case 'running':\n    58→            if (!noStatus) {\n    59→                statusIcon = <ActivityIndicator size=\"small\" color=\"black\" style={{ transform: [{ scaleX: 0.8 }, { scaleY: 0.8 }] }} />;\n    60→            }\n    61→            break;\n    62→        case 'completed':\n    63→            if (!noStatus) {\n    64→                statusIcon = <Ionicons name=\"checkmark-circle\" size={20} color=\"#34C759\" />;\n    65→            }\n    66→            break;\n    67→        case 'error':\n    68→            statusIcon = <Ionicons name=\"close-circle\" size={20} color=\"#FF3B30\" />;\n    69→            break;\n    70→    }\n    71→\n    72→    return (\n    73→        <Container style={styles.container} {...containerProps}>\n    74→            <View style={styles.header}>\n    75→                <View style={styles.headerLeft}>\n    76→                    <Ionicons name={icon as any} size={20} color=\"#5856D6\" />\n    77→                    <View style={styles.titleContainer}>\n    78→                        <Text style={styles.toolName} numberOfLines={1}>{toolTitle}{status ? <Text style={styles.status}>{` ${status}`}</Text> : null}</Text>\n    79→                        {description && (\n    80→                            <Text style={styles.toolDescription} numberOfLines={1}>\n    81→                                {description}\n    82→                            </Text>\n    83→                        )}\n    84→                    </View>\n    85→                    {tool.state === 'running' && (\n    86→                        <View style={styles.elapsedContainer}>\n    87→                            <ElapsedView from={tool.createdAt} />\n    88→                        </View>\n    89→                    )}\n    90→                    {statusIcon}\n    91→                </View>\n    92→            </View>\n    93→\n    94→            {/* Content area - either custom children or tool-specific view */}\n    95→            {(() => {\n    96→\n    97→                // Try to use a specific tool view component first\n    98→                const SpecificToolView = getToolViewComponent(tool.name);\n    99→                if (SpecificToolView) {\n   100→                    return (\n   101→                        <View style={styles.content}>\n   102→                            <SpecificToolView tool={tool} metadata={props.metadata} />\n   103→                            {tool.state === 'error' && tool.result && (\n   104→                                <ToolError message={String(tool.result)} />\n   105→                            )}\n   106→                        </View>\n   107→                    );\n   108→                }\n   109→\n   110→                // Show error state if present\n   111→                if (tool.state === 'error' && tool.result) {\n   112→                    return (\n   113→                        <View style={styles.content}>\n   114→                            <ToolError message={String(tool.result)} />\n   115→                        </View>\n   116→                    );\n   117→                }\n   118→\n   119→                if (minimal) {\n   120→                    return null;\n   121→                }\n   122→\n   123→                // Fall back to