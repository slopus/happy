+    private createSessionState(info: SessionInfo): SessionState {
+        return {
+            info,
+            messages: [],
+            permissions: [],
+            questions: [],
+            todos: [],
+            status: { type: 'idle' },
+        };
+    }
+
+    private upsertSessionInfo(info: SessionInfo): void {
+        const key = info.id as string;
+        const existing = this.state.sessions.get(key);
+        if (!existing) {
+            this.state.sessions.set(key, this.createSessionState(info));
+            this.notifyStateChange();
+            return;
+        }
+
+        existing.info = info;
+        this.notifyStateChange();
+    }
