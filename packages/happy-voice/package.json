{
    "name": "happy-voice",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev:api": "tsx --env-file=.env.local sources/main.ts api",
        "dev:worker": "tsx --env-file=.env.local sources/main.ts worker",
        "dev:all": "tsx --env-file=.env.local sources/main.ts all",
        "build": "tsc --noEmit -p tsconfig.json",
        "start:api": "tsx sources/main.ts api",
        "start:worker": "tsx sources/main.ts worker",
        "start:all": "tsx sources/main.ts all",
        "typecheck": "tsc --noEmit -p tsconfig.json"
    },
    "dependencies": {
        "@fastify/cors": "^10.0.1",
        "@livekit/agents": "^1.0.42",
        "@livekit/agents-plugin-cartesia": "1.0.42",
        "@livekit/agents-plugin-elevenlabs": "1.0.43",
        "@livekit/agents-plugin-livekit": "^1.0.42",
        "@livekit/agents-plugin-openai": "1.0.42",
        "@livekit/agents-plugin-silero": "^1.0.42",
        "@livekit/noise-cancellation-node": "^0.1.9",
        "@livekit/protocol": "^1.44.0",
        "@livekit/rtc-node": "^0.13.24",
        "dotenv": "^16.4.5",
        "fastify": "^5.2.0",
        "fastify-type-provider-zod": "^4.0.2",
        "livekit-server-sdk": "^2.15.0",
        "tsx": "^4.19.2",
        "zod": "3.25.76"
    },
    "devDependencies": {
        "@types/node": "^20.12.3",
        "typescript": "5.9.3"
    }
}
