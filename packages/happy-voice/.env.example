NODE_ENV=development
HOST=0.0.0.0
PORT=3040

# Shared key used by happy-app/happy-server when calling happy-voice.
VOICE_PUBLIC_KEY=replace_me

# LiveKit (Cloud or self-hosted)
LIVEKIT_URL=http://your-project.livekit.cloud
LIVEKIT_WS_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=replace_me
LIVEKIT_API_SECRET=replace_me
LIVEKIT_AGENT_NAME=happy-voice-agent
LIVEKIT_ROOM_TTL_SECONDS=3600
LIVEKIT_TOKEN_TTL_SECONDS=600

# Voice pipeline defaults (official STT + LLM + TTS pattern)
AGENT_STT=assemblyai/universal-streaming:en
AGENT_LLM=openai/gpt-4.1-mini
AGENT_TTS=cartesia/sonic-3:9626c31c-bec5-4cca-baa8-f8ba9e84c8bc
# Optional system prompt to prime the voice agent's behavior.
AGENT_WELCOME_MESSAGE=Say hello and ask what the user wants to build.
# How ready-event replies are played:
# - best_effort: can be interrupted by user speech (default, ElevenLabs-like)
# - strict: avoid interruptions for ready-event playout
AGENT_READY_PLAYOUT_MODE=best_effort
# Optional model used only for ready-event spoken summarization.
# Default falls back to AGENT_LLM.
AGENT_READY_SUMMARY_MODEL=
# Timeout for ready-event summarization LLM call (milliseconds)
AGENT_READY_SUMMARY_TIMEOUT_MS=7000
# Max chars from latest AI reply sent into summarization prompt
AGENT_READY_SUMMARY_INPUT_MAX_CHARS=2200
# Endpointing (turn split) sensitivity:
# Larger min delay means short pauses are less likely to be treated as end-of-sentence.
AGENT_MIN_ENDPOINTING_DELAY_MS=1600
AGENT_MAX_ENDPOINTING_DELAY_MS=7000
# Whether to print all LLM request/response payloads in worker logs.
AGENT_LOG_LLM_IO=true

# Prompt templates (can be overridden by mounting files into the container)
PROMPT_VOICE_MAIN_FILE=prompts/voice-main.system.txt
PROMPT_VOICE_TOOL_FOLLOWUP_FILE=prompts/voice-tool-followup.system.txt
PROMPT_VOICE_READY_SUMMARY_FILE=prompts/voice-ready-summary.system.txt
PROMPT_RECENT_VOICE_MESSAGES=12
PROMPT_RECENT_APP_CONTEXT_MESSAGES=12
PROMPT_RECENT_MAX_CHARS=6000

# Optional bridge for tool execution (messageClaudeCode/manageSession/etc)
TOOL_BRIDGE_BASE_URL=http://localhost:3031
TOOL_BRIDGE_API_KEY=replace_me_same_as_happy_server_voice_tool_bridge_key
TOOL_BRIDGE_TIMEOUT_MS=10000

# Provider keys (set the ones your model stack needs)
OPENAI_API_KEY=
ASSEMBLYAI_API_KEY=
CARTESIA_API_KEY=
