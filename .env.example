# Example env file for the self-host setup scripts in scripts/.
# Copy to .env at the repo root and fill in real values. .env is gitignored —
# never commit it.
#
# All scripts under scripts/ source this file when it exists, so a single
# source of truth covers server + client + viewer configuration.

# ─── Server identity ──────────────────────────────────────────────────────
# Where the server lives. Used to build serverUrl on every client.
# Hostname or IP — must be reachable from clients.
HAPPY_SERVER_HOST=<SERVER_HOST>
# Public port Caddy listens on (must match between server and clients).
HAPPY_PUBLIC_PORT=3006
# Computed: full HTTP URL — clients write this into ~/.happy/settings.json.
# Leave as is unless you're using a non-standard scheme/path.
HAPPY_SERVER_URL=http://${HAPPY_SERVER_HOST}:${HAPPY_PUBLIC_PORT}

# ─── Basic auth gate on /v1/auth* (Caddy) ─────────────────────────────────
# Picked once. The bcrypt is what Caddyfile actually checks; the plaintext
# and URL-encoded forms are convenience for client config + the register
# script.
HAPPY_BASIC_AUTH_USER=happy
HAPPY_BASIC_AUTH_PASS=<PLAINTEXT_PASSWORD>
# URL-encode the password (/ -> %2F, + -> %2B, = -> %3D, : -> %3A, @ -> %40).
# Used to build http://user:url-enc-pass@host URLs for the register script.
HAPPY_BASIC_AUTH_PASS_URLENC=<URL_ENCODED_PASSWORD>
# bcrypt hash output of HAPPY_BASIC_AUTH_PASS — generate via:
#   ~/bin/caddy hash-password --plaintext "$HAPPY_BASIC_AUTH_PASS"
# (only needed by setup-happy-server.sh)
HAPPY_BASIC_AUTH_PASS_BCRYPT='<BCRYPT_HASH>'
# Computed: URL with creds inlined — used as input to the register script.
HAPPY_BASIC_AUTH_URL=http://${HAPPY_BASIC_AUTH_USER}:${HAPPY_BASIC_AUTH_PASS_URLENC}@${HAPPY_SERVER_HOST}:${HAPPY_PUBLIC_PORT}

# ─── Server-internal secret ───────────────────────────────────────────────
# Signs JWTs and HMACs vendor IDs. Generate via `openssl rand -hex 32`.
# Rotating invalidates every issued JWT. Server-side only — do not put on
# client machines.
HANDY_MASTER_SECRET=<HEX_64_BYTES>

# ─── SSH topology ─────────────────────────────────────────────────────────
# SSH config alias of the server (used by setup-happy-server.sh + tunnel).
HAPPY_SERVER_SSH=<SERVER_SSH_ALIAS>
# Whitespace-separated list of SSH aliases for client machines that should
# be auto-configured by scripts/setup-clients-all.sh (if you write one).
HAPPY_CLIENT_SSH_LIST="<CLIENT1_SSH_ALIAS> <CLIENT2_SSH_ALIAS>"
# SSH alias used by the Windows client script for the local-forward (so the
# browser can reach the webapp via http://localhost:<port> — secure context
# for crypto.subtle). Typically same as HAPPY_SERVER_SSH.
HAPPY_SSH_TUNNEL_HOST=${HAPPY_SERVER_SSH}

# ─── Versions / paths ─────────────────────────────────────────────────────
# Pin to a version that still ships the `happy server` subcommand
# (later 1.3.x npm builds removed it).
HAPPY_CLI_VERSION=1.1.10-beta.4
# Where setup-happy-server.sh clones the repo on the server.
HAPPY_SRC=$HOME/code/happy
# Where ~/.happy lives (override for dev environments).
HAPPY_HOME_DIR=$HOME/.happy
# Where the Linux client script puts standalone Node if Node 20+ is missing.
HAPPY_NODE_INSTALL_PATH=$HOME/local
# Caddy version (only needs to be high enough for `basic_auth` directive).
CADDY_VERSION=2.8.4
