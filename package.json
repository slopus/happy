{
    "name": "monorepo",
    "private": true,
    "scripts": {
        "cli": "yarn workspace happy-coder cli",
        "release": "node ./scripts/release.cjs",
        "web": "yarn workspace happy-app web",
        "postinstall": "node ./scripts/postinstall.cjs",
        "env:new": "npx tsx scripts/environments.ts new",
        "env:list": "npx tsx scripts/environments.ts list",
        "env:use": "npx tsx scripts/environments.ts use",
        "env:remove": "npx tsx scripts/environments.ts remove",
        "env:current": "npx tsx scripts/environments.ts current",
        "env:server": "npx tsx scripts/environments.ts run server",
        "env:web": "npx tsx scripts/environments.ts run web",
        "env:ios": "npx tsx scripts/environments.ts run ios",
        "env:android": "npx tsx scripts/environments.ts run android",
        "env:cli": "npx tsx scripts/environments.ts run cli",
        "env:tailscale": "npx tsx scripts/environments.ts tailscale"
    },
    "workspaces": {
        "packages": [
            "packages/happy-app",
            "packages/happy-agent",
            "packages/happy-cli",
            "packages/happy-server",
            "packages/happy-wire"
        ],
        "nohoist": [
            "**/zod",
            "**/react",
            "**/react-dom",
            "**/react-native",
            "**/react-native/**",
            "**/react-native-edge-to-edge/**",
            "**/react-native-incall-manager/**"
        ]
    },
    "packageManager": "yarn@1.22.22"
}
